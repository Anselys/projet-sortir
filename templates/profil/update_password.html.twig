{% extends 'base.html.twig' %}

{% block title %}{{ parent() }} | Modifier mon mot de passe{% endblock %}

{% block main %}

    <div class="row justify-content-center">
        <div class="card text-white bg-secondary mb-3" style="max-width: 32rem;">
            <div class="card-header d-flex align-items-center justify-content-center" style="min-height: 60px;">
                <h2 class="card-title mb-0">
                    Modifier mon mot de passe
                </h2>
            </div>
            <div class="card-body mt-4">
                {{ form_errors(update_password_form) }}
                {{ form_start(update_password_form) }}
                {{ form_widget(update_password_form) }}
                <input class="form-check-input" type="checkbox" id="toggle-password" />
                <label class="form-check-label" for="toggle-password">Afficher le mot de passe</label>

                <script>
                    const oldPassword = document.getElementById("update_password_oldPassword");
                    const newPasswordFirst = document.getElementById("update_password_newPassword_first")
                    const newPasswordSecond = document.getElementById("update_password_newPassword_second")
                    const togglePassword = document.getElementById("toggle-password");
                    togglePassword.addEventListener("click", toggleClicked);
                    function toggleClicked() {
                        oldPassword.classList.toggle("visible");
                        newPasswordFirst.classList.toggle("visible");
                        newPasswordSecond.classList.toggle("visible");
                        if (this.checked) {
                            oldPassword.type = "text";
                            newPasswordFirst.type = "text";
                            newPasswordSecond.type = "text";
                        } else {
                            oldPassword.type = "password";
                            newPasswordFirst.type = "password";
                            newPasswordSecond.type = "password";
                        }
                    }
                </script>
                <div class="text-center mt-5 mb-3">
                    <button class="btn btn-primary">Modifier mon mot de passe</button>
                </div>
                <div class="text-center mb-3">
                    <button class="btn btn-dark" onclick="history.back()">Retour</button>
                </div>
                {{ form_end(update_password_form) }}
            </div>
        </div>
    </div>
{% endblock %}

